function handleImageClick(event) {
	var x = event.offsetX;
	var y = event.offsetY;

	var canvas = document.createElement('canvas');
	var context = canvas.getContext('2d');
	var image = new Image();
	image.src = originalImageSrc;
	canvas.width = image.width;
	canvas.height = image.height;
	context.drawImage(image, 0, 0);

	context.strokeStyle = 'blue';
	context.beginPath();
	context.moveTo(x, 0);
	context.lineTo(x, canvas.height);
	context.moveTo(0, y);
	context.lineTo(canvas.width, y);
	context.stroke();

	event.target.src = canvas.toDataURL();

	var xElements = document.querySelectorAll('[id^="captcha_x"]');
	var yElements = document.querySelectorAll('[id^="captcha_y"]');
	xElements.forEach(function (xElement) {
		xElement.value = x;
	});
	yElements.forEach(function (yElement) {
		yElement.value = y;
	});
}

function showCaptchas() {
	var divs = document.getElementsByClassName("captcha-div");
	var button = document.getElementById("show-captcha-button");

	for (var i = 0; i < divs.length; i++) {
		divs[i].style.display = "";
	}

	button.style.display = "none";

	getCaptcha();

}
function newCaptcha() {
	updateCaptchaElements("data:image/png;base64,", "");
	setTimeout(getCaptcha, 5000);

}

window.addEventListener("keydown", e => {
	if (e.key == "Enter" && (e.ctrlKey || e.metaKey)) {
		if (form = e.target.closest("form[name=post]")) {
			form.querySelector("input[name=post]").click();
		}
	}
});
