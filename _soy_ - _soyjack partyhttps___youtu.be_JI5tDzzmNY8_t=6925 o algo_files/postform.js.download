
function openPostForm() {
	return false;
}
rememberStuff();


var originalImageSrc;
var intervalHandle;



getCaptcha = function () {
	fetch('/inc/mccaptcha/entrypoint.php?mode=captcha')
		.then(response => {
			if (!response.ok) {
				throw Error(response.statusText);
			}
			return response.json();
		})
		.then(data => {
			originalImageSrc = data.base64Image;
			updateCaptchaElements(originalImageSrc, data.guid);
		})
		.catch(error => {
			console.error('Error fetching captcha:', error);
			updateCaptchaElements("data:image/png;base64,", "");
			setTimeout(getCaptcha, 5000);
		});
	clearInterval(intervalHandle);
	intervalHandle = setInterval(getCaptcha, 90000);
};

function updateCaptchaElements(imageSrc, guid) {
	var captchaImages = document.querySelectorAll('[id^="captcha_image"]');
	var captchaGuids = document.querySelectorAll('[id^="captcha_guid"]');

	captchaImages.forEach(function (image) {
		image.src = imageSrc;
	});

	captchaGuids.forEach(function (guidElement) {
		guidElement.value = guid;
	});
}

document.addEventListener('click', function (event) {
	var target = event.target;
	if (target && target.id === 'captcha_image') {
		handleImageClick(event);
	}
});

